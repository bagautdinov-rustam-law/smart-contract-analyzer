# === Yandex AI Studio ===

# API-ключ из Yandex Cloud (можно указывать несколько через запятую)
VITE_DEEPSEEK_API_KEYS=your_yandex_api_key_here
VITE_API_KEY=your_yandex_api_key_here

# Базовый URL OpenAI-совместимого API Yandex AI Studio
DEEPSEEK_API_URL=https://llm.api.cloud.yandex.net/v1

# Модель (подставьте ваш Folder ID)
VITE_DEEPSEEK_MODEL=gpt://your_folder_id/yandexgpt/latest

# Folder ID для заголовка OpenAI-Project
YANDEX_FOLDER_ID=your_folder_id

# Параметры стабильности запросов
DEEPSEEK_TIMEOUT_MS=120000
DEEPSEEK_RETRY_COUNT=3

# Application Configuration
NODE_ENV=development

# Database Configuration (for production)
# DATABASE_URL=your_database_connection_string

# Server Configuration
PORT=5000
HOST=0.0.0.0

# Session Configuration (for production)
# SESSION_SECRET=your_session_secret_here

# Instructions:
# 1. Copy this file to .env
# 2. Replace your_yandex_api_key_here with your actual Yandex API key
# 3. Replace your_folder_id with your Yandex Cloud Folder ID
# 4. Keep .env file private and never commit it to version control
